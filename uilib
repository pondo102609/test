                local minVal = s.minimum_value or 0
                local maxVal = s.maximum_value or 100
                local currentVal = s.value or minVal
                
                local function updateValue(val)
                    currentVal = math.clamp(val, minVal, maxVal)
                    local percent = (currentVal - minVal) / (maxVal - minVal)
                    Fill.Size = UDim2.new(percent, 0, 1, 0)
                    Knob.Position = UDim2.new(percent, -6, 0.5, -6)
                    ValueLabel.Text = s.round_number and tostring(math.floor(currentVal)) or tostring(math.floor(currentVal * 10) / 10)
                    if s.callback then s.callback(currentVal) end
                end
                
                updateValue(currentVal)
                
                local dragging = false
                Knob.MouseButton1Down:Connect(function()
                    dragging = true
                end)
                
                Services.UserInputService.InputChanged:Connect(function(input)
                    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                        local pos = math.clamp((input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
                        updateValue(minVal + (maxVal - minVal) * pos)
                    end
                end)
                
                Services.UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = false
                    end
                end)
