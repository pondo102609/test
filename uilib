local function randomName()
    local chars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
    local result = ""
    for i = 1, 16 do
        result = result .. chars:sub(math.random(1, #chars), math.random(1, #chars))
    end
    return result
end

