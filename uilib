                    dropHeight = dropHeight + 28
                end
                
                DropList.Size = UDim2.new(1, 0, 0, dropHeight)
                
                local open = false
                Button.MouseButton1Click:Connect(function()
                    open = not open
                    DropList.Visible = open
                    Arrow.Text = open and "▲" or "▼"
                end)
            end
            
            function elements:CreateTextbox(s)
                local Row = Instance.new("Frame")
                Row.Name = randomName()
                Row.Size = UDim2.new(1, 0, 0, 55)
                Row.BackgroundTransparency = 1
                Row.Parent = OptionsArea
                
                local Label = Instance.new("TextLabel")
                Label.Name = randomName()
                Label.Size = UDim2.new(1, 0, 0, 16)
                Label.Position = UDim2.new(0, 0, 0, 0)
                Label.BackgroundTransparency = 1
                Label.Text = s.title or "Input"
                Label.TextColor3 = Color3.fromRGB(200, 200, 220)
                Label.TextSize = 11
                Label.Font = Enum.Font.GothamSemibold
                Label.TextXAlignment = Enum.TextXAlignment.Left
                Label.Parent = Row
                
                local Box = Instance.new("TextBox")
                Box.Name = randomName()
                Box.Size = UDim2.new(1, 0, 0, 28)
                Box.Position = UDim2.new(0, 0, 0, 22)
                Box.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
                Box.Text = s.default or ""
                Box.PlaceholderText = s.placeholder or "Enter text..."
                Box.TextColor3 = Color3.fromRGB(200, 200, 220)
                Box.PlaceholderColor3 = Color3.fromRGB(100, 100, 120)
                Box.TextSize = 11
                Box.Font = Enum.Font.Gotham
                Box.ClearTextOnFocus = false
                Box.Parent = Row
                
                local BoxCorner = Instance.new("UICorner")
                BoxCorner.CornerRadius = UDim.new(0, 4)
                BoxCorner.Parent = Box
                
                Box.FocusLost:Connect(function()
                    if s.callback then s.callback(Box.Text) end
                end)
            end
            
            return elements
        end
        
        return {CreateModule = CreateModule}
    end
    
    return {
        CreateTab = CreateTab,
        SendNotification = function(notif)
            local notifFrame = Instance.new("Frame")
            notifFrame.Name = randomName()
            notifFrame.Size = UDim2.new(0, 280, 0, 0)
            notifFrame.Position = UDim2.new(1, -290, 1, -10)
            notifFrame.AnchorPoint = Vector2.new(1, 1)
            notifFrame.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
            notifFrame.BackgroundTransparency = 0.05
            notifFrame.BorderSizePixel = 0
            notifFrame.AutomaticSize = Enum.AutomaticSize.Y
            notifFrame.Parent = ScreenGui
            
            local notifCorner = Instance.new("UICorner")
            notifCorner.CornerRadius = UDim.new(0, 6)
            notifCorner.Parent = notifFrame
            
            local notifStroke = Instance.new("UIStroke")
            notifStroke.Color = Color3.fromRGB(220, 40, 75)
            notifStroke.Thickness = 1
            notifStroke.Transparency = 0.5
            notifStroke.Parent = notifFrame
            
            local notifPad = Instance.new("UIPadding")
            notifPad.PaddingTop = UDim.new(0, 8)
            notifPad.PaddingBottom = UDim.new(0, 8)
            notifPad.PaddingLeft = UDim.new(0, 10)
            notifPad.PaddingRight = UDim.new(0, 10)
            notifPad.Parent = notifFrame
            
            local notifLayout = Instance.new("UIListLayout")
            notifLayout.Padding = UDim.new(0, 4)
            notifLayout.SortOrder = Enum.SortOrder.LayoutOrder
            notifLayout.Parent = notifFrame
            
            local Title = Instance.new("TextLabel")
            Title.Name = randomName()
            Title.Size = UDim2.new(1, 0, 0, 18)
            Title.BackgroundTransparency = 1
            Title.Text = notif.title or "Notification"
            Title.TextColor3 = Color3.fromRGB(220, 40, 75)
            Title.TextSize = 13
            Title.Font = Enum.Font.GothamSemibold
            Title.TextXAlignment = Enum.TextXAlignment.Left
            Title.Parent = notifFrame
            
            local Body = Instance.new("TextLabel")
            Body.Name = randomName()
            Body.Size = UDim2.new(1, 0, 0, 14)
            Body.BackgroundTransparency = 1
            Body.Text = notif.text or ""
            Body.TextColor3 = Color3.fromRGB(180, 180, 200)
            Body.TextSize = 11
            Body.Font = Enum.Font.Gotham
            Body.TextXAlignment = Enum.TextXAlignment.Left
            Body.TextWrapped = true
            Body.AutomaticSize = Enum.AutomaticSize.Y
            Body.Parent = notifFrame
            
            task.delay(notif.duration or 3, function()
                Services.TweenService:Create(notifFrame, TweenInfo.new(0.3), {Position = UDim2.new(1, 10, 1, -10)}):Play()
                task.wait(0.35)
                notifFrame:Destroy()
            end)
            
            Services.TweenService:Create(notifFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Position = UDim2.new(1, -290, 1, -10)}):Play()
        end
    }
end

return SimpleUI
